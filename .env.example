APP_NAME=Enterprise AI Assistant
APP_ENV=development
LOG_LEVEL=INFO

# 企业部署建议生产开启：
# AUTH_ENABLED=true
# ADMIN_TOKEN=请设置足够长的随机令牌
# CORS_ORIGINS=https://your-domain.com
AUTH_ENABLED=false
ADMIN_TOKEN=
CORS_ORIGINS=*
MAX_UPLOAD_MB=20

# 国产模型供应商预设：
# deepseek / qwen / zhipu / moonshot / yi / siliconflow / openai / custom
MODEL_PROVIDER=deepseek

# 通用 OpenAI-compatible 配置。大多数国产模型厂商都支持这种协议。
API_KEY=
BASE_URL=
CHAT_MODEL=

# 兼容旧变量名。已有 OPENAI_* 配置也能继续用。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Embedding 配置：
# auto: 有 API Key 时用兼容 Embedding API，否则用本地 Hash Embedding
# api: 强制调用兼容 Embedding API
# local: 强制使用本地 Hash Embedding，适合演示和离线开发
EMBEDDING_PROVIDER=auto
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
OPENAI_EMBEDDING_MODEL=
LOCAL_EMBEDDING_DIMENSIONS=384

RAW_DATA_DIR=./data/raw
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION_NAME=enterprise_knowledge
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50
